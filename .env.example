# FinPulse Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.

# --- Required ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Database (optional — defaults to local SQLite file) ---
# For production, use a managed Postgres instance, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/finpulse
DATABASE_URL=sqlite:///finpulse.db

# --- Optional overrides (defaults shown) ---
FINPULSE_MODEL_ID=llama-3.3-70b-versatile
FINPULSE_HOST=127.0.0.1
FINPULSE_PORT=7777
FINPULSE_RELOAD=false
FINPULSE_CACHE_TTL=300
FINPULSE_LOG_LEVEL=INFO
